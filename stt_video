#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""
stt_video - Unified Speech-to-Text Wrapper

A wrapper script that provides a unified interface for transcribing video/audio
files using different STT backends (Speechmatics, OpenAI, AssemblyAI) or
downloading existing transcripts from video platforms (YouTube, etc.).

Supports both local files and URLs. For URLs, automatically downloads audio
using yt-dlp-priv.py (preferred) or falls back to yt-dlp, youtube-dl, or
curl/wget for direct media URLs.

Usage:
    stt_video [options] <file_or_url> [-- backend_args...]

Examples:
    # Transcribe local file with default backend (speechmatics)
    stt_video video.mp4

    # Transcribe YouTube video with OpenAI backend
    stt_video -b openai "https://youtube.com/watch?v=xyz"

    # Download existing YouTube subtitles (prefer manual, fallback to auto)
    stt_video -b youtube "https://youtube.com/watch?v=xyz"

    # Download only manual (creator-uploaded) subtitles
    stt_video -b youtube-sub "https://youtube.com/watch?v=xyz"

    # Transcribe with speaker diarization
    stt_video -s 3 -l de video.mp4

    # Pass additional arguments to backend
    stt_video video.mp4 -- --operating-point enhanced

Environment Variables:
    STT_VIDEO_BACKEND: Default backend (speechmatics, openai, assemblyai, youtube, etc.)
                       Default: speechmatics
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


# Supported STT backends and their script names
BACKENDS = {
    "speechmatics": "stt_video_using_speechmatics.sh",
    "openai": "stt_video_using_openai.sh",
    "assemblyai": "stt_video_using_assemblyai.sh",
}

# Transcript pseudo-backends (download existing transcripts instead of running STT)
# These use yt-dlp-priv.py to fetch subtitles from video platforms
TRANSCRIPT_BACKENDS = {
    # YouTube-specific
    "youtube": {"provider": "youtube", "prefer": "manual", "fallback": "auto"},
    "yt": {"provider": "youtube", "prefer": "manual", "fallback": "auto"},
    "youtube-sub": {"provider": "youtube", "prefer": "manual", "fallback": None},
    "yt-sub": {"provider": "youtube", "prefer": "manual", "fallback": None},
    "youtube-auto": {"provider": "youtube", "prefer": "auto", "fallback": None},
    "yt-auto": {"provider": "youtube", "prefer": "auto", "fallback": None},
    # Generic (auto-detect provider from URL)
    "transcript": {"provider": "auto", "prefer": "manual", "fallback": "auto"},
    "transcript-sub": {"provider": "auto", "prefer": "manual", "fallback": None},
    "transcript-auto": {"provider": "auto", "prefer": "auto", "fallback": None},
}

# All STT backend names for -b all (excludes transcript backends)
ALL_BACKENDS = list(BACKENDS.keys())

# All available backends (STT + transcript)
ALL_AVAILABLE_BACKENDS = list(BACKENDS.keys()) + list(TRANSCRIPT_BACKENDS.keys())

# Media file extensions for direct download detection
MEDIA_EXTENSIONS = {
    ".mp3", ".mp4", ".m4a", ".wav", ".webm", ".ogg", ".flac",
    ".aac", ".mkv", ".avi", ".mov", ".wmv", ".opus",
}


def detect_transcript_provider(url: str) -> str | None:
    """
    Auto-detect transcript provider from URL.

    Args:
        url: Video URL

    Returns:
        Provider name ('youtube', 'vimeo', etc.) or None if unknown.
    """
    url_lower = url.lower()

    # YouTube
    if "youtube.com" in url_lower or "youtu.be" in url_lower:
        return "youtube"

    # Vimeo (future support)
    if "vimeo.com" in url_lower:
        return "vimeo"

    # Dailymotion (future support)
    if "dailymotion.com" in url_lower or "dai.ly" in url_lower:
        return "dailymotion"

    return None


def is_url(path: str) -> bool:
    """Check if the input is a URL."""
    return path.startswith("http://") or path.startswith("https://")


def is_direct_media_url(url: str) -> bool:
    """Check if URL points directly to a media file."""
    # Remove query parameters for extension check
    path = url.split("?")[0].split("#")[0]
    return any(path.lower().endswith(ext) for ext in MEDIA_EXTENSIONS)


def find_download_tool() -> tuple[list[str], str] | None:
    """
    Find the best available download tool.

    Returns:
        Tuple of (command_list, tool_name) or None if no tool found.
    """
    # Priority 1: yt-dlp-priv.py with --audio flag
    if shutil.which("yt-dlp-priv.py"):
        return (["yt-dlp-priv.py", "--audio"], "yt-dlp-priv.py")

    # Priority 2: yt-dlp
    if shutil.which("yt-dlp"):
        return (["yt-dlp", "-x", "--audio-format", "mp3"], "yt-dlp")

    # Priority 3: youtube-dl
    if shutil.which("youtube-dl"):
        return (["youtube-dl", "-x", "--audio-format", "mp3"], "youtube-dl")

    return None


def find_direct_download_tool() -> tuple[str, list[str]] | None:
    """
    Find tool for direct media URL download.

    Returns:
        Tuple of (tool_name, base_command) or None if no tool found.
    """
    if shutil.which("aria2c"):
        return ("aria2c", ["aria2c"])
    if shutil.which("curl"):
        return ("curl", ["curl", "-L", "-o"])
    if shutil.which("wget"):
        return ("wget", ["wget", "-O"])
    return None


def _find_audio_files(directory: Path) -> list[Path]:
    """
    Find audio files in directory, preferring original formats over derived mp3.

    Priority:
    1. Original audio formats (.opus, .m4a, .wav, .webm) - most recent
    2. Simple .mp3 files (not .xxx.mp3)
    3. Any .mp3 file as last resort

    This prevents cascading file extensions like .opus.mp3.mp3.mp3
    """
    # Original format files (prefer these)
    original_exts = [".opus", ".m4a", ".wav", ".webm", ".ogg", ".flac", ".aac"]
    original_files = []
    for ext in original_exts:
        original_files.extend(directory.glob(f"*{ext}"))

    # Filter out files with cascading extensions (e.g., .opus.mp3 should not match .opus)
    original_files = [f for f in original_files if not str(f).endswith(('.mp3', '.txt', '.json', '.vtt', '.srt'))]

    if original_files:
        # Return most recently modified
        return sorted(original_files, key=lambda p: p.stat().st_mtime, reverse=True)

    # mp3 files - prefer those without cascading extensions
    mp3_files = list(directory.glob("*.mp3"))
    simple_mp3 = [f for f in mp3_files if not any(f.name.endswith(f"{ext}.mp3") for ext in original_exts)]

    if simple_mp3:
        return sorted(simple_mp3, key=lambda p: p.stat().st_mtime, reverse=True)

    # Fallback: any mp3, preferring shorter names (less cascading)
    if mp3_files:
        return sorted(mp3_files, key=lambda p: (len(p.name), -p.stat().st_mtime))

    return []


def download_from_url(url: str, output_dir: str | None = None) -> str | None:
    """
    Download audio from URL using best available tool.

    Args:
        url: URL to download from
        output_dir: Optional output directory (overrides default)

    Returns:
        Path to downloaded file or None on failure.
    """
    # Try video platform downloaders first
    download_tool = find_download_tool()

    if download_tool:
        cmd, tool_name = download_tool
        print(f"> Downloading audio using {tool_name}...", file=sys.stderr)

        full_cmd = cmd.copy()

        # Add output directory if specified
        if output_dir and tool_name == "yt-dlp-priv.py":
            # yt-dlp-priv.py uses its own destination logic by default
            # We'd need to use environment variables or modify script
            # For now, let it use default and find the file
            pass

        full_cmd.append(url)

        try:
            result = subprocess.run(full_cmd, check=True, capture_output=True, text=True)
            # Try to extract the output file path from stdout
            # yt-dlp-priv.py prints destination directory at the end
            for line in result.stdout.strip().split("\n"):
                if line and os.path.isdir(line):
                    # Find audio file - prefer original formats over derived mp3
                    audio_files = _find_audio_files(Path(line))
                    if audio_files:
                        return str(audio_files[0])

            # If we can't find the file, try stderr
            for line in result.stderr.strip().split("\n"):
                if line.startswith("> Destination directory:"):
                    continue
                if line and os.path.isdir(line):
                    audio_files = _find_audio_files(Path(line))
                    if audio_files:
                        return str(audio_files[0])

            print(f"> WARNING: Download completed but couldn't locate output file", file=sys.stderr)
            print(f"> Check the download directory manually", file=sys.stderr)
            return None

        except subprocess.CalledProcessError as e:
            print(f"> WARNING: {tool_name} failed: {e}", file=sys.stderr)
            if e.stderr:
                print(f"> {e.stderr}", file=sys.stderr)

    # Try direct download for media URLs
    if is_direct_media_url(url):
        direct_tool = find_direct_download_tool()
        if direct_tool:
            tool_name, base_cmd = direct_tool
            print(f"> Downloading direct media URL using {tool_name}...", file=sys.stderr)

            # Determine output filename
            filename = url.split("/")[-1].split("?")[0]
            if output_dir:
                output_path = os.path.join(output_dir, filename)
            else:
                output_path = os.path.join(tempfile.gettempdir(), filename)

            if tool_name == "aria2c":
                cmd = base_cmd + ["-d", os.path.dirname(output_path), "-o", os.path.basename(output_path), url]
            else:
                cmd = base_cmd + [output_path, url]

            try:
                subprocess.run(cmd, check=True)
                if os.path.exists(output_path):
                    return output_path
            except subprocess.CalledProcessError as e:
                print(f"> WARNING: {tool_name} failed: {e}", file=sys.stderr)

    print(f"> ERROR: No suitable download tool found for URL", file=sys.stderr)
    print(f"> Install one of: yt-dlp-priv.py, yt-dlp, youtube-dl, curl, wget, aria2c", file=sys.stderr)
    return None


def find_backend_script(backend: str) -> str | None:
    """
    Find the backend script in PATH.

    Args:
        backend: Backend name (speechmatics, openai, assemblyai)

    Returns:
        Script name if found, None otherwise.
    """
    if backend not in BACKENDS:
        print(f"> ERROR: Unknown backend '{backend}'", file=sys.stderr)
        print(f"> Available backends: {', '.join(BACKENDS.keys())}", file=sys.stderr)
        return None

    script_name = BACKENDS[backend]
    if shutil.which(script_name):
        return script_name

    print(f"> ERROR: Backend script not found: {script_name}", file=sys.stderr)
    print(f"> Ensure it is installed and in your PATH", file=sys.stderr)
    return None


def run_transcript_backend(
    url: str,
    backend: str,
    language: str | None,
    output_dir: Path | None = None,
) -> tuple[int, list[Path]]:
    """
    Download transcripts from video platform using yt-dlp-priv.py.

    Args:
        url: Video URL
        backend: Transcript backend name (youtube, yt, transcript, etc.)
        language: Language code or None for auto-detect
        output_dir: Optional output directory

    Returns:
        Tuple of (exit_code, list_of_transcript_files)
    """
    config = TRANSCRIPT_BACKENDS.get(backend)
    if not config:
        print(f"> ERROR: Unknown transcript backend: {backend}", file=sys.stderr)
        return (1, [])

    # Auto-detect provider if needed
    provider = config["provider"]
    if provider == "auto":
        provider = detect_transcript_provider(url)
        if not provider:
            print(f"> ERROR: Cannot detect transcript provider for URL: {url}", file=sys.stderr)
            print(f"> Use a provider-specific backend like 'youtube' or 'yt'", file=sys.stderr)
            return (1, [])

    # Validate URL matches provider for provider-specific backends
    if config["provider"] != "auto":
        detected = detect_transcript_provider(url)
        if detected != provider:
            print(f"> ERROR: Backend '{backend}' requires {provider} URL, got: {detected or 'unknown'}", file=sys.stderr)
            return (1, [])

    # Check yt-dlp-priv.py is available
    if not shutil.which("yt-dlp-priv.py"):
        print(f"> ERROR: yt-dlp-priv.py not found in PATH", file=sys.stderr)
        print(f"> Install yt-dlp-priv.py to use transcript backends", file=sys.stderr)
        return (1, [])

    # Determine transcript type preference
    prefer = config["prefer"]
    fallback = config["fallback"]

    # Build yt-dlp-priv.py command
    cmd = ["yt-dlp-priv.py", "--transcript"]

    # Add transcript type
    if fallback:
        cmd.extend(["--transcript-type", "both"])
    else:
        cmd.extend(["--transcript-type", prefer])

    # Add language if specified
    if language:
        if language.lower() == "all":
            cmd.extend(["--transcript-lang", "all"])
        else:
            cmd.extend(["--transcript-lang", language])

    cmd.append(url)

    print(f"> [{backend}] Downloading {prefer} transcripts from {provider}...", file=sys.stderr)
    if fallback:
        print(f">   (will fall back to {fallback} if {prefer} not available)", file=sys.stderr)
    print(f"> Command: {' '.join(cmd)}", file=sys.stderr)

    try:
        result = subprocess.run(cmd, capture_output=True, text=True)

        if result.returncode != 0:
            # Check if it's a "no subtitles" error vs real failure
            if "no subtitles" in result.stderr.lower() or "no transcript" in result.stderr.lower():
                if fallback is None:
                    print(f"> [{backend}] No {prefer} subtitles available", file=sys.stderr)
                else:
                    print(f"> [{backend}] No subtitles available", file=sys.stderr)
            else:
                print(f"> [{backend}] Download failed: {result.stderr}", file=sys.stderr)
            return (result.returncode, [])

        # Get status to find downloaded files
        status_cmd = ["yt-dlp-priv.py", "--status", "--json", url]
        status_result = subprocess.run(status_cmd, capture_output=True, text=True)

        downloaded_files = []
        if status_result.returncode == 0:
            try:
                status = json.loads(status_result.stdout)
                subtitles = status.get("subtitles", [])

                # Filter by type preference if not "both"
                for sub in subtitles:
                    sub_type = sub.get("type", "unknown")
                    sub_path = sub.get("path", "")

                    # Include if matches preference or if we want both
                    if fallback:  # "both" mode - include all
                        if sub_path and os.path.exists(sub_path):
                            downloaded_files.append(Path(sub_path))
                    elif sub_type == prefer:
                        if sub_path and os.path.exists(sub_path):
                            downloaded_files.append(Path(sub_path))

            except json.JSONDecodeError:
                pass

        if downloaded_files:
            print(f"> [{backend}] Downloaded {len(downloaded_files)} transcript file(s):", file=sys.stderr)
            for f in downloaded_files:
                print(f">   {f}", file=sys.stderr)
            return (0, downloaded_files)
        else:
            print(f"> [{backend}] No transcript files found after download", file=sys.stderr)
            return (1, [])

    except FileNotFoundError:
        print(f"> ERROR: yt-dlp-priv.py not found", file=sys.stderr)
        return (1, [])
    except KeyboardInterrupt:
        print(f"\n> Interrupted", file=sys.stderr)
        return (130, [])


def run_stt(
    file_path: str,
    backend: str,
    language: str,
    speakers: int | None,
    pass_through_args: list[str],
) -> int:
    """
    Run STT on the given file using the specified backend.

    Args:
        file_path: Path to audio/video file
        backend: STT backend name
        language: Language code (guaranteed to have value after prompt_for_missing_args)
        speakers: Number of speakers (guaranteed for speechmatics/assemblyai, None for openai)
        pass_through_args: Additional arguments to pass to backend

    Returns:
        Exit code from backend script.
    """
    script = find_backend_script(backend)
    if not script:
        return 1

    # Build command with positional args in order expected by backend scripts:
    # - speechmatics: FILE [SPEAKERS [LANGUAGE]]
    # - assemblyai: FILE [SPEAKERS [LANGUAGE]]
    # - openai: FILE [LANGUAGE]
    cmd = [script, file_path]

    if backend == "openai":
        # OpenAI: FILE LANGUAGE (no speakers support)
        cmd.append(language)
    else:
        # Speechmatics/AssemblyAI: FILE SPEAKERS LANGUAGE
        cmd.append(str(speakers))
        cmd.append(language)

    # Add pass-through arguments
    cmd.extend(pass_through_args)

    print(f"> Running {backend} STT on: {file_path}", file=sys.stderr)
    print(f"> Command: {' '.join(cmd)}", file=sys.stderr)

    try:
        result = subprocess.run(cmd)
        return result.returncode
    except FileNotFoundError:
        print(f"> ERROR: Script not found: {script}", file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print(f"\n> Interrupted", file=sys.stderr)
        return 130


def check_transcript_status(file_path: str, backends: list[str], json_output: bool = False) -> dict:
    """
    Check what transcripts already exist for a file.

    Args:
        file_path: Path to audio/video file
        backends: List of backend names to check
        json_output: If True, returns structured data; if False, prints human-readable

    Returns:
        Dict with status for each backend.
    """
    results = {
        "file": file_path,
        "file_exists": os.path.exists(file_path),
        "backends": {}
    }

    if not results["file_exists"]:
        if json_output:
            print(json.dumps(results, indent=2))
        else:
            print(f"File: {file_path} (not found)")
        return results

    for backend in backends:
        script = BACKENDS.get(backend)
        if not script or not shutil.which(script):
            results["backends"][backend] = {"error": "script not found"}
            continue

        cmd = [script, "--status", "--json", file_path]
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, check=True)
            backend_status = json.loads(result.stdout)
            results["backends"][backend] = backend_status
        except subprocess.CalledProcessError as e:
            results["backends"][backend] = {"error": str(e)}
        except json.JSONDecodeError:
            results["backends"][backend] = {"error": "invalid JSON response"}

    if json_output:
        print(json.dumps(results, indent=2))
    else:
        print(f"File: {file_path}")
        for backend, status in results["backends"].items():
            if "error" in status:
                print(f"  {backend}: error - {status['error']}")
            elif status.get("transcript_exists"):
                size = status.get("transcript_size_bytes", 0)
                path = status.get("transcript_path", "")
                legacy = " [legacy]" if status.get("transcript_legacy") else ""
                print(f"  {backend}: exists ({size} bytes){legacy}")
                print(f"            {path}")
            else:
                print(f"  {backend}: not found")

    return results


def parse_backends(backend_arg: str) -> list[str]:
    """
    Parse backend argument which can be:
    - Single backend: "speechmatics", "youtube", "yt"
    - Multiple backends: "speechmatics,openai"
    - All STT backends: "all"

    Supports both STT backends (speechmatics, openai, assemblyai) and
    transcript backends (youtube, yt, transcript, etc.).

    Returns:
        List of backend names.
    """
    if backend_arg.lower() == "all":
        return ALL_BACKENDS.copy()

    backends = [b.strip() for b in backend_arg.split(",") if b.strip()]

    # Validate backends (check both STT and transcript backends)
    invalid = [b for b in backends if b not in BACKENDS and b not in TRANSCRIPT_BACKENDS]
    if invalid:
        print(f"> ERROR: Unknown backend(s): {', '.join(invalid)}", file=sys.stderr)
        print(f"> STT backends: {', '.join(BACKENDS.keys())}", file=sys.stderr)
        print(f"> Transcript backends: {', '.join(TRANSCRIPT_BACKENDS.keys())}", file=sys.stderr)
        print(f"> Use 'all' for all STT backends", file=sys.stderr)
        sys.exit(1)

    return backends


def prompt_for_missing_args(args: argparse.Namespace) -> None:
    """
    Prompt user for missing speakers/language BEFORE download.
    This ensures all required input is collected upfront so the user
    can start the command and walk away.

    Modifies args in place.
    """
    backend = args.backend

    # Prompt for speakers if not provided and backend supports diarization
    if args.speakers is None and backend in ("speechmatics", "assemblyai"):
        if backend == "speechmatics":
            # Prompt taken from stt_video_using_speechmatics.sh
            # Please check that script for consistency if prompts change
            prompt = "Max speakers [0] (0==any):"
        else:  # assemblyai
            # Prompt taken from stt_video_using_assemblyai.sh
            # Please check that script for consistency if prompts change
            prompt = "Expected speakers [0] (0==any):"

        try:
            response = input(prompt).strip()
            args.speakers = int(response) if response else 0
        except ValueError:
            print(f"> WARNING: Invalid number, using 0 (auto)", file=sys.stderr)
            args.speakers = 0
        except EOFError:
            # Non-interactive, use default
            args.speakers = 0

    # Prompt for language if not provided
    if args.language is None:
        if backend == "openai":
            # Prompt taken from stt_video_using_openai.sh
            # Please check that script for consistency if prompts change
            default = "auto"
        else:
            # Prompt taken from stt_video_using_speechmatics.sh / stt_video_using_assemblyai.sh
            # Please check those scripts for consistency if prompts change
            default = "en"

        try:
            response = input(f"Language code [{default}]:").strip()
            args.language = response if response else default
        except EOFError:
            # Non-interactive, use default
            args.language = default


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        description="Unified Speech-to-Text wrapper for video/audio files and URLs.",
        epilog="Arguments after '--' are passed directly to the backend script.",
    )

    parser.add_argument(
        "input",
        help="File path or URL to transcribe",
    )

    parser.add_argument(
        "--backend", "-b",
        default=os.environ.get("STT_VIDEO_BACKEND", "speechmatics"),
        help="Backend(s) to use. STT backends: speechmatics, openai, assemblyai. "
             "Transcript backends (download existing subtitles): youtube/yt, youtube-sub/yt-sub, "
             "youtube-auto/yt-auto, transcript, transcript-sub, transcript-auto. "
             "Can be comma-separated (speechmatics,openai) or 'all' for all STT backends. "
             "(default: %(default)s, or STT_VIDEO_BACKEND env var)",
    )

    parser.add_argument(
        "--status",
        action="store_true",
        help="Check if transcripts exist without processing. Reports status for each backend.",
    )

    parser.add_argument(
        "--json",
        action="store_true",
        help="Output status in machine-readable JSON format (use with --status).",
    )

    parser.add_argument(
        "--language", "-l",
        help="Language code (e.g., en, de, fr). Default: en for most backends, auto for openai",
    )

    parser.add_argument(
        "--speakers", "-s",
        type=int,
        help="Number of speakers for diarization (0=auto, 1=no diarization). "
             "Only supported by speechmatics and assemblyai.",
    )

    parser.add_argument(
        "--output-dir", "-o",
        help="Output directory for URL downloads (overrides default destination)",
    )

    # Collect pass-through arguments
    parser.add_argument(
        "pass_through",
        nargs="*",
        help=argparse.SUPPRESS,
    )

    # Handle -- separator for pass-through args
    if argv is None:
        argv = sys.argv[1:]

    # Split at -- separator
    if "--" in argv:
        sep_idx = argv.index("--")
        main_args = argv[:sep_idx]
        pass_through = argv[sep_idx + 1:]
    else:
        main_args = argv
        pass_through = []

    args = parser.parse_args(main_args)
    args.pass_through = pass_through

    return args


def main(argv: list[str] | None = None) -> int:
    """Main entry point."""
    args = parse_args(argv)

    # Parse backend argument into list
    backends = parse_backends(args.backend)

    # Handle --status flag: check what transcripts exist
    if args.status:
        input_path = args.input

        # For URLs, we need to resolve where the file would be downloaded
        if is_url(input_path):
            # Try to get status from yt-dlp-priv.py if available
            if shutil.which("yt-dlp-priv.py"):
                print(f"> Checking download status for URL...", file=sys.stderr)
                try:
                    # Always get JSON to parse properly
                    cmd = ["yt-dlp-priv.py", "--status", "--json", input_path]
                    result = subprocess.run(cmd, capture_output=True, text=True)

                    # Parse JSON output
                    try:
                        dl_status = json.loads(result.stdout)

                        # Find audio file path to check transcripts
                        audio_files = dl_status.get("audio", [])
                        if audio_files:
                            # Use first audio file
                            audio_path = audio_files[0].get("path")
                            if audio_path and os.path.exists(audio_path):
                                print(f"> Audio found: {audio_path}", file=sys.stderr)
                                print(f"> Checking transcript status...\n", file=sys.stderr)
                                check_transcript_status(audio_path, backends, json_output=args.json)
                                return 0

                        # No audio file found - show download status
                        if args.json:
                            print(json.dumps({
                                "url": input_path,
                                "download_status": dl_status,
                                "transcript_status": "no audio downloaded",
                                "backends": {}
                            }, indent=2))
                        else:
                            # Print human-readable download status
                            print(f"URL: {dl_status.get('url', input_path)}")
                            print(f"Video ID: {dl_status.get('video_id', 'unknown')}")
                            print(f"Platform: {dl_status.get('platform', 'unknown')}")
                            print(f"Destination: {dl_status.get('destination_dir', 'unknown')}")

                            videos = dl_status.get("videos", [])
                            print(f"Videos: {len(videos)} found" if videos else "Videos: none downloaded")

                            audio = dl_status.get("audio", [])
                            print(f"Audio: {len(audio)} found" if audio else "Audio: none downloaded")

                            subtitles = dl_status.get("subtitles", [])
                            print(f"Subtitles: {len(subtitles)} found" if subtitles else "Subtitles: none")

                            print(f"\nTranscripts: cannot check - no audio file downloaded yet")
                            print(f"\n> Run without --status to download and transcribe.", file=sys.stderr)
                        return 0

                    except json.JSONDecodeError:
                        print(f"> WARNING: Could not parse yt-dlp-priv.py JSON output", file=sys.stderr)

                except Exception as e:
                    print(f"> WARNING: Could not check URL status: {e}", file=sys.stderr)

            print(f"> ERROR: Cannot check transcript status for URL without downloading first", file=sys.stderr)
            print(f"> Run without --status to download and transcribe, then use --status on the file.", file=sys.stderr)
            return 1

        # Local file status check
        check_transcript_status(input_path, backends, json_output=args.json)
        return 0

    # Separate backends into transcript (pseudo) backends and STT backends
    transcript_backends_to_run = [b for b in backends if b in TRANSCRIPT_BACKENDS]
    stt_backends_to_run = [b for b in backends if b in BACKENDS]

    input_path = args.input
    exit_code = 0
    total_backends = len(transcript_backends_to_run) + len(stt_backends_to_run)
    current_backend_idx = 0

    # --- Handle transcript backends (work directly with URLs) ---
    if transcript_backends_to_run:
        if not is_url(input_path):
            print(f"> ERROR: Transcript backends require a URL, got local file: {input_path}", file=sys.stderr)
            print(f"> Transcript backends download existing subtitles from video platforms.", file=sys.stderr)
            return 1

        print(f"> Input is URL: {input_path}", file=sys.stderr)

        for backend in transcript_backends_to_run:
            current_backend_idx += 1
            if total_backends > 1:
                print(f"\n> [{current_backend_idx}/{total_backends}] Running {backend}...", file=sys.stderr)

            result_code, downloaded_files = run_transcript_backend(
                url=input_path,
                backend=backend,
                language=args.language,
                output_dir=Path(args.output_dir) if args.output_dir else None,
            )

            if result_code != 0:
                exit_code = result_code
                print(f"> [{backend}] Transcript download failed with exit code {result_code}", file=sys.stderr)

    # --- Handle STT backends (need local audio file) ---
    if stt_backends_to_run:
        # Prompt for missing args BEFORE any download
        # This allows user to provide all input upfront and walk away
        prompt_for_missing_args(args)

        file_to_transcribe = None

        # Check if input is URL or file
        if is_url(input_path):
            print(f"> Input is URL: {input_path}", file=sys.stderr)
            file_to_transcribe = download_from_url(input_path, args.output_dir)
            if not file_to_transcribe:
                print(f"> ERROR: Failed to download audio from URL", file=sys.stderr)
                return 1
        else:
            # Local file
            if not os.path.exists(input_path):
                print(f"> ERROR: File not found: {input_path}", file=sys.stderr)
                return 1
            file_to_transcribe = input_path

        # Check which STT backends already have transcripts (skip if already done)
        stt_backends_filtered = []
        for backend in stt_backends_to_run:
            script = BACKENDS.get(backend)
            if script and shutil.which(script):
                # Quick check if transcript already exists
                cmd = [script, "--status", "--json", file_to_transcribe]
                try:
                    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
                    status = json.loads(result.stdout)
                    if status.get("transcript_exists"):
                        print(f"> [{backend}] Transcript already exists, skipping.", file=sys.stderr)
                        continue
                except (subprocess.CalledProcessError, json.JSONDecodeError):
                    pass  # If status check fails, proceed with transcription

            stt_backends_filtered.append(backend)

        # Run STT for each backend
        for backend in stt_backends_filtered:
            current_backend_idx += 1
            if total_backends > 1:
                print(f"\n> [{current_backend_idx}/{total_backends}] Running {backend}...", file=sys.stderr)

            result = run_stt(
                file_path=file_to_transcribe,
                backend=backend,
                language=args.language,
                speakers=args.speakers,
                pass_through_args=args.pass_through,
            )

            if result != 0:
                exit_code = result
                print(f"> [{backend}] STT failed with exit code {result}", file=sys.stderr)

    if total_backends == 0:
        print(f"> No backends specified.", file=sys.stderr)
        return 1

    if total_backends > 1:
        print(f"\n> Processing complete.", file=sys.stderr)

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
